-- [CORE LOGIC - HỆ THỐNG LAZER VÀ PHÁ HỦY ĐẤT]
-- =========================================================
local LazerPart = nil
local HitAttachment = nil
local SelectionBox = nil

-- Cập nhật tọa độ, kích thước to 0.35 và đào hố vật lý
local function UpdateLazerGeometry()
    local char = lp.Character
    local hand = char and (char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm"))
    local mouse = lp:GetMouse()
    
    -- Điều kiện bắn: Phải bật Lazer và (Chế độ Auto hoạt động HOẶC chế độ Click đang nhấn giữ)
    local shouldShoot = lazerActive and (shootMode == "Auto" or (shootMode == "Click" and isClicking))
    
    if not hand or not mouse or not shouldShoot then
        if LazerPart then LazerPart.Transparency = 1 end
        if SelectionBox then SelectionBox.Visible = false end
        if HitAttachment then HitAttachment.Parent = nil end
        return
    end
    
    local startPos = hand.Position
    local targetPos = mouse.Hit.Position
    local distance = (targetPos - startPos).Magnitude
    
    -- Giới hạn khoảng cách tối đa
    if distance > 1000 then
        distance = 1000
        targetPos = startPos + (mouse.Hit.LookVector * 1000)
    end
    
    -- Khởi tạo tia Lazer cực dày (0.35)
    if not LazerPart or not LazerPart.Parent then
        LazerPart = Instance.new("Part")
        LazerPart.Name = "AbzzaitLazerBeam"
        LazerPart.Anchored = true
        LazerPart.CanCollide = false
        LazerPart.Material = Enum.Material.Neon
        LazerPart.Size = Vector3.new(0.35, 0.35, distance) -- TĂNG ĐỘ DÀY LÊN 0.35
        LazerPart.Parent = Workspace
        
        SelectionBox = Instance.new("BoxHandleAdornment", LazerPart)
        SelectionBox.Size = LazerPart.Size
        SelectionBox.AlwaysOnTop = true
        SelectionBox.Transparency = 0.4
        SelectionBox.Adornee = LazerPart
    end
    
    -- Cập nhật thông số tia
    LazerPart.Transparency = 0
    LazerPart.Size = Vector3.new(0.35, 0.35, distance)
    LazerPart.CFrame = CFrame.lookAt(startPos, targetPos) * CFrame.new(0, 0, -distance/2)
    LazerPart.Color = lazerColor
    
    if SelectionBox then
        SelectionBox.Visible = true
        SelectionBox.Size = LazerPart.Size
        SelectionBox.Color3 = lazerColor
    end
    
    -- 🛠️ NÂNG CẤP: KHỬ ĐỊA HÌNH - ĐÀO HỐ PHÁ HỦY ĐẤT REALTIME
    pcall(function()
        local terrain = Workspace:FindFirstChildOfClass("Terrain") or Workspace.Terrain
        if terrain then
            -- Thay thế vật liệu đất tại điểm chạm thành không khí (Air) để tạo hố tròn (bán kính 4.5 studs)
            terrain:FillBall(targetPos, 4.5, Enum.Material.Air)
        end
    end)
    
    -- Kích hoạt hạt tia lửa phát sáng
    if not HitAttachment or not HitAttachment.Parent then
        HitAttachment = Instance.new("Attachment", Workspace.Terrain)
        
        local pe = Instance.new("ParticleEmitter", HitAttachment)
        pe.Texture = "rbxassetid://241594157" 
        pe.Rate = 140
        pe.Lifetime = NumberRange.new(0.2, 0.6)
        pe.Speed = NumberRange.new(4, 12)
        pe.SpreadAngle = Vector2.new(0, 360)
        pe.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(1, 0)})
    end
    
    HitAttachment.Position = targetPos
    local emitter = HitAttachment:FindFirstChildOfClass("ParticleEmitter")
    if emitter then
        emitter.Color = ColorSequence.new(lazerColor)
    end
    
    -- Vụ nổ liên tục nhẹ nếu đang bật Explosion Mode (Kèm âm thanh sinh động)
    if explosionMode and math.random(1, 4) == 1 then
        pcall(function()
            local exp = Instance.new("Explosion")
            exp.Position = targetPos
            exp.BlastRadius = 10
            exp.BlastPressure = 300000
            exp.Parent = Workspace
        end)
    end
end

-- Vòng lặp Render cập nhật vẽ tia
local renderConnection
local function StartRenderLoop()
    if not renderConnection then
        renderConnection = RunService.RenderStepped:Connect(function()
            if _G.AbzzaitLazerSession ~= currentSession then return end
            UpdateLazerGeometry()
        end)
    end
end

local function StopRenderLoop()
    isClicking = false
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end
    if LazerPart then LazerPart:Destroy() LazerPart = nil end
    if SelectionBox then SelectionBox:Destroy() SelectionBox = nil end
    if HitAttachment then HitAttachment:Destroy() HitAttachment = nil end
end

