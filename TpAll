-- [CORE LOGIC - HỆ THỐNG DỊCH CHUYỂN]
-- =========================================================

local function GetTargetsIncludingDummies()
    local targets = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and not whitelistTable[p.Name] and p.Character then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                table.insert(targets, p.Character)
            end
        end
    end
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local hum = obj:FindFirstChild("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if hum and hrp then
                if not Players:GetPlayerFromCharacter(obj) and obj ~= lp.Character and hum.Health > 0 then
                    table.insert(targets, obj)
                end
            end
        end
    end
    return targets
end

local function GetClosestTarget(targets)
    local closestTarget = nil
    local shortestDistance = math.huge
    local myHrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not myHrp then return nil end
    
    for _, target in ipairs(targets) do
        local targetHrp = target:FindFirstChild("HumanoidRootPart")
        if targetHrp then
            local distance = (myHrp.Position - targetHrp.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestTarget = target
            end
        end
    end
    return closestTarget
end

local function RunKillAllLoop()
    if loopKillAllActive then return end
    loopKillAllActive = true
    task.spawn(function()
        while toggledKillAll and _G.AbzzaitKillAllSession == currentSession do
            local targets = GetTargetsIncludingDummies()
            if #targets > 0 then
                local target = nil
                
                if killAllMode == "Random" then
                    target = targets[math.random(1, #targets)]
                elseif killAllMode == "Closest" then
                    target = GetClosestTarget(targets)
                elseif killAllMode == "Closest + Seq" then
                    table.sort(targets, function(a, b)
                        local hrpA = a:FindFirstChild("HumanoidRootPart")
                        local hrpB = b:FindFirstChild("HumanoidRootPart")
                        local myHrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                        if hrpA and hrpB and myHrp then
                            return (myHrp.Position - hrpA.Position).Magnitude < (myHrp.Position - hrpB.Position).Magnitude
                        end
                        return false
                    end)
                    if targetIndex > #targets then targetIndex = 1 end
                    target = targets[targetIndex]
                    targetIndex = targetIndex + 1
                else 
                    if targetIndex > #targets then targetIndex = 1 end
                    target = targets[targetIndex]
                    targetIndex = targetIndex + 1
                end
                
                if target then
                    local myChar = lp.Character
                    local hrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
                    local targetHrp = target:FindFirstChild("HumanoidRootPart")
                    if hrp and targetHrp then
                        local backOffset = targetHrp.CFrame.LookVector * BACK_OFFSET_DISTANCE
                        local targetPos = Vector3.new(targetHrp.Position.X - backOffset.X, targetHrp.Position.Y, targetHrp.Position.Z - backOffset.Z)
                        myChar:PivotTo(CFrame.new(targetPos, targetHrp.Position))
                    end
                end
            end
            task.wait(SPEED_TUNER)
        end
        loopKillAllActive = false
    end)
end

