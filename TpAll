local ToggleBtn

local function ToggleKillAll()
    toggledKillAll = not toggledKillAll
    if toggledKillAll then
        ToggleBtn.Text = "KillAll: ACTIVE (E)"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 30, 30)
        RunKillAllLoop()
    else
        ToggleBtn.Text = "KillAll: OFF (E)"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    end
end

