-- Hàm tạo nút bấm nhanh
local function createButton(parent, text, size, position, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = size
    btn.Position = position
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.Text = text
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 10
    btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- =========================================================
-- [CORE LOGIC - HỆ THỐNG KILLALL (TP ALL)]
-- =========================================================
local toggledKillAll = false
local loopKillAllActive = false
local BACK_OFFSET_DISTANCE = 2.0 -- Khoảng cách đứng sau mục tiêu
local SPEED_TUNER = 0.02 -- Tốc độ delay giữa mỗi lần dịch chuyển

local function GetTargetsIncludingDummies()
    local targets = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp and p.Character then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                table.insert(targets, p.Character)
            end
        end
    end
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local hum = obj:FindFirstChild("Humanoid")
            local hrp = obj:FindFirstChild("HumanoidRootPart")
            if hum and hrp then
                if not Players:GetPlayerFromCharacter(obj) and obj ~= lp.Character and hum.Health > 0 then
                    table.insert(targets, obj)
                end
            end
        end
    end
    return targets
end

local function RunKillAllLoop()
    if loopKillAllActive then 
        return 
    end
    loopKillAllActive = true
    task.spawn(function()
        while toggledKillAll do
            local targets = GetTargetsIncludingDummies()
            if #targets > 0 then
                local target = targets[math.random(1, #targets)]
                local myChar = lp.Character
                local hrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
                local targetHrp = target:FindFirstChild("HumanoidRootPart")
                if hrp and targetHrp then
                    local backOffset = targetHrp.CFrame.LookVector * BACK_OFFSET_DISTANCE
                    local targetPos = Vector3.new(targetHrp.Position.X - backOffset.X, targetHrp.Position.Y, targetHrp.Position.Z - backOffset.Z)
                    myChar:PivotTo(CFrame.new(targetPos, targetHrp.Position))
                end
            end
            task.wait(SPEED_TUNER)
        end
        loopKillAllActive = false
    end)
end

RunService.Heartbeat:Connect(function()
    if toggledKillAll then
        if lp.Character then
            for _, part in pairs(lp.Character:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
        VirtualUser:CaptureController()
        VirtualUser:Button1Down(Vector2.new(0, 0))
    end
end)

