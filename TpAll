        local delta = i.Position - start
        MainFrame.Position = UDim2.new(pos.X.Scale, pos.X.Offset + delta.X, pos.Y.Scale, pos.Y.Offset + delta.Y)
    end
end)

UIS.InputEnded:Connect(function() 
    drag = false 
end)

