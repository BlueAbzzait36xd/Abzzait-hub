-- Thuật toán kiểm tra siêu tốc không gây lag
local function isPartOfPlayerFast(part)
    local parent = part.Parent
    if not parent then return false end
    
    if Players:GetPlayerFromCharacter(parent) then 
        return true 
    end
    
    local grandParent = parent.Parent
    if grandParent and Players:GetPlayerFromCharacter(grandParent) then 
        return true 
    end
    
    return false
end

-- Hàm nhận diện chướng ngại vật tĩnh (Thùng rác, hòm thư, trụ điện...)
local function isDestructibleProp(v)
    local name = v.Name:lower()
    for _, kw in ipairs(propKeywords) do
        if name:find(kw) then
            return true
        end
    end
    return false
end

-- Khóa cài đặt đồ họa mượt nhất của hệ thống
local function ForceSmoothGraphics()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
    pcall(function()
        Lighting.GlobalShadows = false
    end)
    pcall(function()
        Lighting.Brightness = 2
    end)
    pcall(function()
        Lighting.FogEnd = 9e9
    end)
    pcall(function()
        Workspace.Terrain.WaterWaveSize = 0
        Workspace.Terrain.WaterWaveSpeed = 0
        Workspace.Terrain.WaterReflectance = 0
        Workspace.Terrain.WaterDetailSize = 0
    end)
    pcall(function()
        Workspace.LevelOfDetail = Enum.ModelLevelOfDetail.Low 
    end)
end

-- Đơn giản hóa cơ thể nhân vật
local function SimplifyCharacter(char)
    if not char then return end
    task.spawn(function()
        for _, item in ipairs(char:GetDescendants()) do
            pcall(function()
                if item:IsA("Accessory") then
                    local handle = item:FindFirstChild("Handle") or item
                    if handle and handle:IsA("BasePart") then
                        if not originalTransparencies[handle] then
                            originalTransparencies[handle] = handle.Transparency
                        end
                        handle.Transparency = 1 
                    end
                elseif item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
                    table.insert(hiddenAccessories, {item = item, parent = char})
                    item.Parent = nil 
                elseif item:IsA("BasePart") then
                    if not originalMaterials[item] then
                        originalMaterials[item] = item.Material
                        originalColors[item] = item.Color
                    end
                    item.Material = Enum.Material.SmoothPlastic
                    item.Color = Color3.fromRGB(120, 120, 120)
                    item.CastShadow = false 
                    
                    if item:IsA("MeshPart") then
                        item.UsePartColor = true
                    end
                elseif item:IsA("SpecialMesh") then
                    item.TextureID = "" 
                end
            end)
        end
    end)
end

-- Biến đổi toàn bộ bầu trời thành một màu xám phẳng đồng nhất
local function ApplyGraySky()
    pcall(function()
        originalAmbient.Ambient = Lighting.Ambient
        originalAmbient.OutdoorAmbient = Lighting.OutdoorAmbient
        
        for _, child in ipairs(Lighting:GetChildren()) do
            if child:IsA("Sky") or child:IsA("Clouds") or child:IsA("Atmosphere") then
                table.insert(originalSky, {item = child, parent = Lighting})
                child.Parent = nil
            end
        end
        
        local grayAtmos = Instance.new("Atmosphere")
        grayAtmos.Name = "GrayAtmos"
        grayAtmos.Density = 1 
        grayAtmos.Color = Color3.fromRGB(120, 120, 120)
        grayAtmos.Decay = Color3.fromRGB(120, 120, 120)
        grayAtmos.Glare = 0
        grayAtmos.Haze = 0
        grayAtmos.Parent = Lighting
        
        Lighting.Ambient = Color3.fromRGB(120, 120, 120)
        Lighting.OutdoorAmbient = Color3.fromRGB(120, 120, 120)
    end)
end

-- Hợp nhất hàm xử lý tối ưu hóa đơn lẻ cho từng vật thể
local function ProcessInstance(v)
    pcall(function()
        if not isPartOfPlayerFast(v) then
            -- 🛠️ NÂNG CẤP: Xóa sổ các chướng ngại vật tĩnh (Thùng rác, trụ điện...) ngay khi kích hoạt
            if isDestructibleProp(v) then
                v:Destroy()
                return
            end
            
            -- 🛠️ NÂNG CẤP: Tiêu hủy lập tức các mảnh vỡ mất neo vật lý đang bay tự do
            if v:IsA("BasePart") and not v:IsA("Terrain") and not v.Anchored then
                v:Destroy()
                return
            end
            
            -- Hóa xám phẳng toàn bộ bản đồ
            if v:IsA("BasePart") and not v:IsA("Terrain") then
                if not originalMaterials[v] then
                    originalMaterials[v] = v.Material
                    originalColors[v] = v.Color
                end
                v.Material = Enum.Material.SmoothPlastic
                v.Color = Color3.fromRGB(120, 120, 120) 
                v.CastShadow = false 
                
                if v:IsA("MeshPart") then
                    v.UsePartColor = true
                end
            elseif v:IsA("Decal") or v:IsA("Texture") then
                v.Transparency = 1
            elseif v:IsA("SpecialMesh") then
                v.TextureID = ""
            elseif v:IsA("ParticleEmitter") or v:IsA("Sparkles") or v:IsA("Smoke") or v:IsA("Fire") then
                v.Enabled = false
            elseif v:IsA("Model") then
                v.LevelOfDetail = Enum.ModelLevelOfDetail.Low
            end
        end
    end)
end

-- Tối ưu hóa thế giới ban đầu
local function OptimizeWorld()
    local descendants = Workspace:GetDescendants()
    local count = 0
    
    task.spawn(function()
        for _, v in ipairs(descendants) do
            if not fpsActive or _G.AbzzaitFpsSession ~= currentSession then return end
            
            ProcessInstance(v)
            
            count = count + 1
            if count % 300 == 0 then
                task.wait()
            end
        end
    end)
    
    for _, effect in ipairs(Lighting:GetChildren()) do
        pcall(function()
            if effect:IsA("PostEffect") or effect:IsA("Atmosphere") or effect:IsA("Clouds") then
                effect.Enabled = false
            end
        end)
    end
end

-- Khôi phục mọi trạng thái đồ họa cũ của game về mặc định
local function RestoreOriginalGraphics()
    for part, mat in pairs(originalMaterials) do
        if part and part.Parent then
            pcall(function()
                part.Material = mat
                part.Color = originalColors[part]
                part.CastShadow = true
                if part:IsA("MeshPart") then
                    part.UsePartColor = false
                end
            end)
        end
    end
    originalMaterials = {}
    originalColors = {}
    
    for handle, trans in pairs(originalTransparencies) do
        if handle and handle.Parent then
            pcall(function()
                handle.Transparency = trans
            end)
        end
    end
    originalTransparencies = {}
    
    for _, data in ipairs(hiddenAccessories) do
        if data.item and data.parent then
            pcall(function()
                data.item.Parent = data.parent
            end)
        end
    end
    hiddenAccessories = {}
    
    for _, data in ipairs(originalSky) do
        if data.item and data.parent then
            pcall(function()
                data.item.Parent = data.parent
            end)
        end
    end
    originalSky = {}
    
    local customAtmos = Lighting:FindFirstChild("GrayAtmos")
    if customAtmos then
        pcall(function()
            customAtmos:Destroy()
        end)
    end
    
    pcall(function()
        if originalAmbient.Ambient then
            Lighting.Ambient = originalAmbient.Ambient
            Lighting.OutdoorAmbient = originalAmbient.OutdoorAmbient
        end
    end)
    originalAmbient = {}
    
    local descendants = Workspace:GetDescendants()
    task.spawn(function()
        for _, v in ipairs(descendants) do
            pcall(function()
                if v:IsA("Decal") or v:IsA("Texture") then
                    v.Transparency = 0
                elseif v:IsA("ParticleEmitter") or v:IsA("Sparkles") or v:IsA("Smoke") or v:IsA("Fire") then
                    v.Enabled = true
                elseif v:IsA("Model") then
                    v.LevelOfDetail = Enum.ModelLevelOfDetail.High
                end
            end)
        end
    end)
    
    for _, effect in ipairs(Lighting:GetChildren()) do
        pcall(function()
            if effect:IsA("PostEffect") or effect:IsA("Atmosphere") or effect:IsA("Clouds") then
                effect.Enabled = true
            end
        end)
    end
    
    pcall(function()
        Workspace.LevelOfDetail = Enum.ModelLevelOfDetail.High
    end)
end

-- =========================================================
-- [VÒNG LẶP ĐỒNG BỘ TRẠNG THÁI & CHẶN HIỆU ỨNG TSB REALTIME]
-- =========================================================
local loopConnection
local worldStreamConnection 

local function StartLagFix()
    ForceSmoothGraphics()
    ApplyGraySky()
    OptimizeWorld()
    
    -- 1. Hệ thống phát hiện hồi sinh (Áp dụng cho mọi người chơi)
    local function onCharacterAdded(char)
        if fpsActive then
            task.wait(0.5)
            SimplifyCharacter(char)
        end
    end
    
    local function onPlayerAdded(p)
        local conn = p.CharacterAdded:Connect(onCharacterAdded)
        table.insert(playerConnections, conn)
        if p.Character then
            onCharacterAdded(p.Character)
        end
    end
    
    local pAddedConn = Players.PlayerAdded:Connect(onPlayerAdded)
    table.insert(connections, pAddedConn)
    
    for _, p in ipairs(Players:GetPlayers()) do
        onPlayerAdded(p)
    end
    
    -- 2. BỘ GÁC CỔNG THỜI GIAN THỰC NÂNG CẤP (Xóa Movement Blocks, Debris & Props)
    worldStreamConnection = Workspace.DescendantAdded:Connect(function(child)
        if not fpsActive or _G.AbzzaitFpsSession ~= currentSession then return end
        
        pcall(function()
            -- A. Chặn khói bụi, sét vệt đuôi kỹ năng
            if child:IsA("ParticleEmitter") or child:IsA("Smoke") or child:IsA("Fire") or child:IsA("Sparkles") or child:IsA("Beam") or child:IsA("Trail") then
                child:Destroy()
            
            -- B. Chặn mảnh đá vỡ nát, vết nứt đất 3D kỹ năng
            elseif child:IsA("BasePart") and (child.Name:lower():find("rock") or child.Name:lower():find("debris") or child.Name:lower():find("dust") or child.Name:lower():find("shockwave") or child.Name:lower():find("crater")) then
                child:Destroy()
                
            -- C. Chặn khói bụi di chuyển dưới chân, gió lướt
            elseif child:IsA("BasePart") and (child.Name:lower():find("movement") or child.Name:lower():find("dash") or child.Name:lower():find("run") or child.Name:lower():find("step")) then
                child:Destroy()
                
            -- D. Hóa xám phẳng các chi tiết map mới tải thêm (Streaming) hoặc xóa mảnh vỡ mất neo mới sinh
            else
                ProcessInstance(child)
            end
        end)
    end)
    table.insert(connections, worldStreamConnection)
    
    -- Vòng lặp khóa đồ họa mượt liên tục
    loopConnection = RunService.Heartbeat:Connect(function()
        if _G.AbzzaitFpsSession ~= currentSession then return end
        if not fpsActive then return end
        
        ForceSmoothGraphics()
    end)
end

local function StopLagFix()
    if loopConnection then
        loopConnection:Disconnect()
        loopConnection = nil
    end
    if worldStreamConnection then
        worldStreamConnection:Disconnect()
        worldStreamConnection = nil
    end
    -- Ngắt toàn bộ lắng nghe hồi sinh
    for _, conn in ipairs(playerConnections) do
        if conn then
            pcall(function() conn:Disconnect() end)
        end
    end
    playerConnections = {}
    
    RestoreOriginalGraphics()
end

