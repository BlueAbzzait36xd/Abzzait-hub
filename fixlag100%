-- [VÒNG LẶP ĐỒNG BỘ TRẠNG THÁI & CHẶN HIỆU ỨNG TSB REALTIME]
-- =========================================================
local loopConnection
local worldStreamConnection 
local githubHeartbeatConnection

local function StartLagFix()
    ForceSmoothGraphics()
    ApplyGraySky()
    OptimizeWorld()
    
    -- 1. Hệ thống phát hiện hồi sinh (Áp dụng cho TOÀN BỘ người chơi bao gồm cả BẠN)
    local function onCharacterAdded(char)
        if fpsActive then
            task.wait(0.5)
            SimplifyCharacter(char)
        end
    end
    
    local function onPlayerAdded(p)
        local conn = p.CharacterAdded:Connect(onCharacterAdded)
        table.insert(playerConnections, conn)
        if p.Character then
            onCharacterAdded(p.Character)
        end
    end
    
    local pAddedConn = Players.PlayerAdded:Connect(onPlayerAdded)
    table.insert(connections, pAddedConn)
    
    -- Kích hoạt ngay lập tức cho bạn và tất cả người chơi cũ trong server
    for _, p in ipairs(Players:GetPlayers()) do
        onPlayerAdded(p)
    end
    
    -- 2. BỘ GÁC CỔNG THỜI GIAN THỰC NÂNG CẤP (Xóa Movement Blocks, Debris, Props & Đá chiêu thức)
    worldStreamConnection = Workspace.DescendantAdded:Connect(function(child)
        if not fpsActive or _G.AbzzaitFpsSession ~= currentSession then return end
        
        pcall(function()
            -- 🛠️ TỐI ƯU: Nếu một phụ kiện mới được thêm vào nhân vật người chơi, lập tức làm ẩn nó
            if isPartOfPlayerFast(child) then 
                local char = child:FindFirstAncestorOfClass("Model")
                if char and char:FindFirstChildOfClass("Humanoid") then
                    task.spawn(function()
                        SimplifyCharacter(char)
                    end)
                end
                return 
            end
            if child:IsDescendantOf(Gui) then return end
            
            -- A. Chống đá chiêu thức mọc lên: Tiêu diệt ngay lập tức bất kỳ BasePart/Khối gạch nào mọc lên động
            if child:IsA("BasePart") then
                child:Destroy()
                return
            end
            
            -- B. Chặn các hạt khói bụi, sét vệt đuôi kỹ năng
            if child:IsA("ParticleEmitter") or child:IsA("Smoke") or child:IsA("Fire") or child:IsA("Sparkles") or child:IsA("Beam") or child:IsA("Trail") then
                child:Destroy()
                return
            
            -- C. Chặn mảnh đá vỡ nát, vết nứt đất kỹ năng dưới dạng Model/Folder
            elseif child:IsA("Model") or child:IsA("Folder") then
                local name = child.Name:lower()
                if name:find("effect") or name:find("vfx") or name:find("fx") or name:find("skill") or name:find("rock") or name:find("debris") or name:find("crater") or name:find("impact") then
                    task.wait() 
                    child:Destroy()
                    return
                end
            -- D. Tự động tắt bảng tên 3D hoặc SurfaceGui mới xuất hiện (Weakest Dummy)
            elseif child:IsA("BillboardGui") or child:IsA("SurfaceGui") then
                child.Enabled = false
            else
                ProcessInstance(child)
            end
        end)
    end)
    table.insert(connections, worldStreamConnection)
    
    -- 3. ĐỒNG BỘ BỘ DỌN RÁC THƯ MỤC THROWN TỪ GITHUB (Tối ưu hóa 14ms một lần)
    local ThrownFolder = Workspace:FindFirstChild("Thrown")
    local LastNom = 0
    
    githubHeartbeatConnection = RunService.Heartbeat:Connect(function()
        if _G.AbzzaitFpsSession ~= currentSession then return end
        if not fpsActive then return end
        
        local Now = os.clock()
        if Now - LastNom >= 0.014285714285714 and ThrownFolder then
            LastNom = Now
            eat(ThrownFolder)
        end
    end)
    table.insert(connections, githubHeartbeatConnection)
    
    -- Vòng lặp khóa đồ họa mượt liên tục
    loopConnection = RunService.Heartbeat:Connect(function()
        if _G.AbzzaitFpsSession ~= currentSession then return end
        if not fpsActive then return end
        
        ForceSmoothGraphics()
    end)
end

local function StopLagFix()
    if loopConnection then
        loopConnection:Disconnect()
        loopConnection = nil
    end
    if worldStreamConnection then
        worldStreamConnection:Disconnect()
        worldStreamConnection = nil
    end
    if githubHeartbeatConnection then
        githubHeartbeatConnection:Disconnect()
        githubHeartbeatConnection = nil
    end
    for _, conn in ipairs(playerConnections) do
        if conn then
            pcall(function() conn:Disconnect() end)
        end
    end
    playerConnections = {}
    
    RestoreOriginalGraphics()
end

